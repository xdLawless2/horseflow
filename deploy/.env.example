# Bind to a private interface such as a Tailscale address.
HORSEFLOW_BIND_ADDRESS=127.0.0.1

# Use a stable GPU UUID from: nvidia-smi --query-gpu=uuid,name --format=csv
HORSEFLOW_GPU=GPU-00000000-0000-0000-0000-000000000000

HORSEFLOW_LLM_MODEL=qwen3:8b
HORSEFLOW_ASR_MODEL=large-v3
HORSEFLOW_LANGUAGE=en
HORSEFLOW_COMPUTE_TYPE=float16

# Comma-separated vocabulary and an optional natural-language context sentence.
HORSEFLOW_DICTIONARY=Linux,Docker,Ollama,Whisper
HORSEFLOW_ASR_PROMPT=Accurate conversational dictation containing technical terms and proper nouns.

HORSEFLOW_OLLAMA_MODELS=/var/lib/horseflow/ollama
HORSEFLOW_ASR_MODELS=/var/lib/horseflow/asr
